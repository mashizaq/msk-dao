# Server Configuration
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/msk-dao
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Ethereum Configuration
ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETHEREUM_CHAIN_ID=11155111
ETHEREUM_PRIVATE_KEY=your_ethereum_private_key
ETHEREUM_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=your_solana_private_key_base58
SOLANA_TOKEN_MINT=11111111111111111111111111111111

# Stacks/Bitcoin Configuration
STACKS_API_URL=https://api.testnet.hiro.so
STACKS_PRIVATE_KEY=your_stacks_private_key
STACKS_CONTRACT_ADDRESS=ST1234567890ABCDEF1234567890ABCDEF1234567890

# Polygon Configuration
POLYGON_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_CHAIN_ID=80001

# Base Configuration
BASE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_CHAIN_ID=84532

# Stablecoin Addresses (USDT/USDC)
USDT_ADDRESS_ETHEREUM=0x0000000000000000000000000000000000000000
USDC_ADDRESS_ETHEREUM=0x0000000000000000000000000000000000000000
USDT_ADDRESS_POLYGON=0x0000000000000000000000000000000000000000

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
